{
  "name": "ai-project-management-tool",
  "version": "1.0.0",
  "description": "Full-stack MERN project management tool with JWT auth, Kanban board, dashboards, and reporting.",
  "private": true,
  "scripts": {
    "install:server": "cd server && npm install",
    "install:client": "cd client && npm install",
    "install:all": "npm run install:server && npm run install:client",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm start",
    "seed": "cd server && npm run seed",
    "test:server": "cd server && npm test",
    "test:client": "cd client && npm test -- --watchAll=false",
    "build:client": "cd client && npm run build"
  },
  "keywords": ["mern", "project-management", "react", "express", "mongodb", "kanban"],
  "license": "MIT"
}
